# Shared
NODE_ENV=development
DATABASE_URL=postgresql://cadsploy:cadsploy@localhost:5432/cadsploy?schema=public
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=change-me-to-a-long-random-secret-min-32-chars
SESSION_SECRET=change-me-to-another-long-random-secret

# Public domains
BASE_DOMAIN=localhost
PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Deploy runtime
CADSPLOY_WORKDIR=.cadsploy/workdir
CADSPLOY_DOCKER_NETWORK=cadsploy-net
CADSPLOY_DEFAULT_MEMORY=512m
CADSPLOY_DEFAULT_CPUS=0.5
CADSPLOY_CADDYFILE=./infra/Caddyfile.generated
CADSPLOY_CADDY_RELOAD_COMMAND=
# Example: docker exec cadsploy-caddy caddy reload --config /etc/caddy/Caddyfile
